#!/bin/bash
set -euo pipefail

# Pre-commit Hook
# Runs validation before committing

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$(dirname "$SCRIPT_DIR")")"

echo "Running pre-commit checks..."

# Run markdown linting
echo "Checking markdown files..."
if command -v markdownlint &> /dev/null; then
  if ! markdownlint --config "$ROOT_DIR/.markdownlint.json" "$ROOT_DIR" --ignore node_modules; then
    echo "Markdown linting failed!"
    exit 1
  fi
fi

# Run shell linting
echo "Checking shell scripts..."
if command -v shellcheck &> /dev/null; then
  if ! find "$ROOT_DIR" -name "*.sh" -type f -exec shellcheck {} \;; then
    echo "Shell linting failed!"
    exit 1
  fi
fi

# Run validation
echo "Validating assets..."
if ! "$ROOT_DIR/core/validator/validate-all.sh"; then
  echo "Validation failed!"
  exit 1
fi

echo "Pre-commit checks passed!"