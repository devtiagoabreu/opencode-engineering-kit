{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent",
  "description": "Schema for OpenCode Engineering Kit Agents",
  "type": "object",
  "required": ["name", "description", "version", "author", "compatible", "personas"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatible": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["opencode", "claude-code", "cursor", "copilot"]
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Skills this agent can use"
    },
    "personas": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Agent personas"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      }
    }
  }
}